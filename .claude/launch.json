{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "mockups",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:mockups"],
      "port": 5173
    },
    {
      "name": "mobile-web",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "npm run web --prefix apps/mobile -- --port \"$PORT\""],
      "port": 8081,
      "autoPort": true
    },
    {
      "name": "mobile-dist",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8094", "--directory", "apps/mobile/dist"],
      "port": 8094
    }
  ]
}
