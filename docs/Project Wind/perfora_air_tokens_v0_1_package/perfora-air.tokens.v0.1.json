  "$metadata": {
    "name": "Perfora Air Tokens",
    "version": "0.1.0",
    "status": "draft",
    "date": "2026-07-09",
    "description": "A light, matte, atmospheric token set for translating invisible context into surface density, subtle light, and directional flow.",
    "principles": [
      "Matte over glossy",
      "Signal over sparkle",
      "Density carries meaning",
      "Light is feedback, not decoration",
      "Motion is contextual and quiet by default",
      "Accessibility modes are first-class tokens"
    ]
  },
