{
  "expo": {
    "name": "WeatherON",
    "slug": "weatheron",
    "scheme": "weatheron",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../../assets/icon/icon-light-v2-1024.png",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "backgroundColor": "#071E33",
      "barStyle": "light-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#071E33",
      "barStyle": "light-content"
    },
    "plugins": [
      "expo-navigation-bar",
      "./plugins/withWeatheronAndroidDarkIcon"
    ],
    "splash": {
      "image": "../../assets/icon/icon-primary-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#071E33"
    },
    "assetBundlePatterns": [
      "../../assets/icon/*",
      "../../assets/outfits/*",
      "../../assets/place-categories/*",
      "../../assets/wordmark/*",
      "../../assets/onboarding/*",
      "../../assets/ui-icons/*"
    ],
    "ios": {
      "version": "1.0.0",
      "supportsTablet": false,
      "bundleIdentifier": "com.weatheron.mobile",
      "icon": {
        "light": "../../assets/icon/icon-light-v2-1024.png",
        "dark": "../../assets/icon/icon-dark-1024.png"
      },
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ko",
        "NSLocationWhenInUseUsageDescription": "현재 위치 기준 날씨와 외출 준비 추천을 제공하기 위해 위치 권한을 사용합니다.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "11"
    },
    "android": {
      "package": "com.weatheron.mobile",
      "versionCode": 10,
      "icon": "../../assets/icon/icon-light-v2-1024.png",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "../../assets/icon/android/icon-adaptive-foreground-light-1024.png",
        "backgroundImage": "../../assets/icon/android/icon-adaptive-background-light-1024.png",
        "monochromeImage": "../../assets/icon/icon-mono-1024.png",
        "backgroundColor": "#F8FBFF"
      }
    },
    "web": {
      "favicon": "../../assets/icon/icon-primary-32.png"
    },
    "extra": {
      "ruleVersion": "weatheron-rules-0.1.0",
      "eas": {
        "projectId": "3bf39144-92a4-48a9-8bd8-ae09daf2a817"
      }
    },
    "owner": "weatheron"
  }
}
