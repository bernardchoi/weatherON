EXPO_PUBLIC_WEATHER_CLIENT=fixture

# proxy mode: recommended for web/native app runtime
# EXPO_PUBLIC_WEATHER_CLIENT=proxy
# EXPO_PUBLIC_WEATHER_API_BASE_URL=http://127.0.0.1:8091
# 서버 PROXY_ACCESS_TOKEN을 켠 경우에만 함께 설정 (x-weatheron-proxy-token 헤더로 전송)
# EXPO_PUBLIC_WEATHER_API_TOKEN=
# iOS에서 Apple WeatherKit을 우선 사용. 서버/Worker WeatherKit 환경변수 설정 필요.
# EXPO_PUBLIC_IOS_WEATHER_PROVIDER=weatherkit

# Direct live adapter debugging is done by scripts/check-weather-live.mjs.
# Do not expose KMA keys with EXPO_PUBLIC_* in app builds.
# Server-only KMA_SERVICE_KEY belongs in apps/server/.env.local or Secret Manager.

# optional overrides
EXPO_PUBLIC_WEATHER_TIMEOUT_MS=8000
EXPO_PUBLIC_KMA_FORECAST_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getVilageFcst
EXPO_PUBLIC_OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
