WEATHER_SERVER_HOST=127.0.0.1
WEATHER_SERVER_PORT=8091

# server only
KMA_SERVICE_KEY=replace-with-data-go-kr-decoding-service-key

# optional: 설정하면 /weather, /places, /routes 요청에
# x-weatheron-proxy-token 헤더가 일치해야 응답한다.
# 앱 빌드의 EXPO_PUBLIC_WEATHER_API_TOKEN과 함께 배포해야 기존 클라이언트가 끊기지 않는다.
# PROXY_ACCESS_TOKEN=

# optional overrides
WEATHER_TIMEOUT_MS=8000
WEATHER_CACHE_TTL_MS=600000
PLACE_CACHE_TTL_MS=1800000
ROUTE_CACHE_TTL_MS=600000
KMA_FORECAST_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getVilageFcst
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
KAKAO_LOCAL_KEYWORD_URL=https://dapi.kakao.com/v2/local/search/keyword.json
KAKAO_DIRECTIONS_URL=https://apis-navi.kakaomobility.com/v1/directions
GOOGLE_MAPS_API_KEY=
GOOGLE_DISTANCE_MATRIX_URL=https://maps.googleapis.com/maps/api/distancematrix/json
KAKAO_REST_API_KEY=
